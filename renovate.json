{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":semanticCommitType(chore)",
    ":semanticPrefixFixDepsChoreOthers",
    "config:best-practices",
    "group:dotNetCore",
    "schedule:daily"
  ],
  "enabledManagers": [
    "github-actions",
    "nuget"
  ],
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "groupName": "ApplicationInsights",
      "matchPackageNames": [
        "/ApplicationInsights/"
      ]
    },
    {
      "groupName": "Dotnet",
      "matchPackageNames": [
        "dotnet-sdk",
        "mcr.microsoft.com/dotnet/aspnet",
        "mcr.microsoft.com/dotnet/sdk",
        "mcr.microsoft.com/dotnet/runtime",
        "mcr.microsoft.com/dotnet/runtime-deps"
      ],
      "extends": [
        ":disableMajorUpdates",
        ":pinDigestsDisabled"
      ]
    },
    {
      "groupName": "System.CommandLine",
      "matchPackageNames": [
        "System.CommandLine{/,}**"
      ]
    },
    {
      "groupName": "XUnit",
      "matchPackageNames": [
        "xunit{/,}**"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "Pipeline dependencies"
    },
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "3 days"
    }
  ],
  "prConcurrentLimit": 50,
  "prHourlyLimit": 0,
  "dependencyDashboard": true,
  "gitAuthor": "Renovate Bot <bot@renovateapp.com>",
  "automergeType": "branch",
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "automerge": true,
  "ignoreTests": false,
  "commitMessageAction": "update",
  "automergeStrategy": "squash",
  "commitMessagePrefix": "chore(all): ",
  "platformAutomerge": true,
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  }
}
